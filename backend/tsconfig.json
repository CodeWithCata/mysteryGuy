{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "dist",
    
    // CHANGE THIS LINE:
    "rootDir": "..",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "6.0", 
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../shared/*"] 
    }
  },
  "include": ["src", "../shared"],
  "exclude": ["node_modules", "dist"]
}